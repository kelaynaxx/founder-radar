# =============================================================================
# Founder Radar — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Every variable listed here is consumed by `founder_radar.config.settings`.
# Add new variables there as the project grows.
# =============================================================================

# -----------------------------------------------------------------------------
# Reddit API credentials
# -----------------------------------------------------------------------------
# Create a "script" app at https://www.reddit.com/prefs/apps
# - name: anything (e.g. "founder-radar")
# - type: script
# - redirect_uri: http://localhost:8080 (required even for script apps)
# Then copy the client id (under the app name) and the secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=founder-radar/0.1 (by /u/your_username)

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible endpoint)
# -----------------------------------------------------------------------------
# Used by Phase 3+. The default endpoint is OpenAI; you can also point this at
# any OpenAI-compatible local server (LM Studio, Ollama with openai shim, vLLM,
# etc.) by changing LLM_BASE_URL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite for Phase 1. To switch to PostgreSQL later, set e.g.:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/founder_radar
DATABASE_URL=sqlite:///data/founder_radar.db

# -----------------------------------------------------------------------------
# Pipeline limits
# -----------------------------------------------------------------------------
# Default number of posts to fetch per subreddit per run.
SCAN_LIMIT_PER_SUBREDDIT=50
# Comma-separated list of subreddits to scan by default.
DEFAULT_SUBREDDITS=entrepreneur,startups,SaaS,smallbusiness,indiehackers

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
REPORTS_DIR=reports
DATA_DIR=data
LOGS_DIR=logs
# -----------------------------------------------------------------------------
# Embeddings (Phase 2)
# -----------------------------------------------------------------------------
# Backend selector. Options:
#   sentence-transformers  local model, ~1 GB install (needs [embeddings] extra)
#   null                   deterministic placeholder vectors, no model load
#   openai                 OpenAI-compatible /embeddings endpoint
EMBEDDING_BACKEND=sentence-transformers
# Model name passed to the backend. For sentence-transformers this is a
# HuggingFace hub id. Defaults to a small, fast model good for smoke tests.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Clustering (Phase 2)
# -----------------------------------------------------------------------------
# Cosine similarity threshold. Two posts with similarity >= this end up in
# the same cluster. 0.75 is a reasonable default for sentence-transformer
# embeddings; raise to 0.85+ for tighter clusters, lower to 0.6 for looser.
CLUSTER_SIMILARITY_THRESHOLD=0.75

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO