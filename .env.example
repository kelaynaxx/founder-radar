# =============================================================================
# Founder Radar — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Every variable listed here is consumed by `founder_radar.config.settings`.
# Add new variables there as the project grows.
# =============================================================================

# -----------------------------------------------------------------------------
# Reddit API credentials
# -----------------------------------------------------------------------------
# Create a "script" app at https://www.reddit.com/prefs/apps
# - name: anything (e.g. "founder-radar")
# - type: script
# - redirect_uri: http://localhost:8080 (required even for script apps)
# Then copy the client id (under the app name) and the secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=founder-radar/0.1 (by /u/your_username)

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible endpoint)
# -----------------------------------------------------------------------------
# Used by Phase 3+. The default endpoint is OpenAI; you can also point this at
# any OpenAI-compatible local server (LM Studio, Ollama with openai shim, vLLM,
# etc.) by changing LLM_BASE_URL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Reasoning-model support (V2.1, MiniMax-M3 / DeepSeek R1 / o1-style models)
# -----------------------------------------------------------------------------
# Some models (MiniMax-M3, DeepSeek R1, OpenAI o1) inline their reasoning
# trace into message.content as <think>...</think> blocks BEFORE the
# real answer. That breaks strict JSON parsing. The three knobs below
# tell the OpenAI-compatible provider how to handle that.
#
# Run `founder-radar llm-smoke-test` after changing any of these to
# verify the new combination produces parseable JSON.
#
# LLM_REASONING_SPLIT=true
#   Sends `extra_body.reasoning_split=true` to the provider. MiniMax-M3
#   and DeepSeek honour this to return the reasoning trace in a
#   separate field instead of inlining it into message.content.
#   Default: false.
#
# LLM_THINKING_MODE controls the reasoning-mode field. Allowed:
#   - "disabled"   no reasoning
#   - "adaptive"   model decides
#   - "enabled"    always reason
#   - "empty"      send the field with an empty value to disable
#                  reasoning explicitly (MiniMax-M3 convention).
#   Default: "empty".
#
# LLM_RESPONSE_FORMAT is the OpenAI `response_format` field value.
#   - "json_object"  constrain output to valid JSON (default)
#   - "none"          skip the field entirely
#
# Worked example for MiniMax-M3:
#   LLM_BASE_URL=https://api.MiniMax.chat/v1
#   LLM_API_KEY=<your MiniMax-M3 key>
#   LLM_MODEL=MiniMax-M3
#   LLM_REASONING_SPLIT=true
#   LLM_THINKING_MODE=disabled
#   LLM_RESPONSE_FORMAT=json_object
LLM_REASONING_SPLIT=false
LLM_THINKING_MODE=empty
LLM_RESPONSE_FORMAT=json_object

# HTTP timeout (seconds) for LLM provider requests. Reasoning models
# can be slow. Default 120. Lower it for quick smoke tests; raise it if
# you see httpx.TimeoutException.
LLM_TIMEOUT_SECONDS=120

# Strip <think>...</think> blocks from the model's response before
# returning it to callers. Default true — this is a safety net for
# reasoning models that ignore reasoning_split and inline the trace
# into message.content. Set false only when you want to inspect the
# raw response (e.g. via llm-smoke-test --debug-request).
LLM_STRIP_THINKING_ALWAYS=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite for Phase 1. To switch to PostgreSQL later, set e.g.:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/founder_radar
DATABASE_URL=sqlite:///data/founder_radar.db

# -----------------------------------------------------------------------------
# Pipeline limits
# -----------------------------------------------------------------------------
# Default number of posts to fetch per subreddit per run.
SCAN_LIMIT_PER_SUBREDDIT=50
# Comma-separated list of subreddits to scan by default.
DEFAULT_SUBREDDITS=entrepreneur,startups,SaaS,smallbusiness,indiehackers

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
REPORTS_DIR=reports
DATA_DIR=data
LOGS_DIR=logs
# -----------------------------------------------------------------------------
# Embeddings (Phase 2)
# -----------------------------------------------------------------------------
# Backend selector. Options:
#   sentence-transformers  local model, ~1 GB install (needs [embeddings] extra)
#   null                   deterministic placeholder vectors, no model load
#   openai                 OpenAI-compatible /embeddings endpoint
EMBEDDING_BACKEND=sentence-transformers
# Model name passed to the backend. For sentence-transformers this is a
# HuggingFace hub id. Defaults to a small, fast model good for smoke tests.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Clustering (Phase 2)
# -----------------------------------------------------------------------------
# Cosine similarity threshold. Two posts with similarity >= this end up in
# the same cluster. 0.75 is a reasonable default for sentence-transformer
# embeddings; raise to 0.85+ for tighter clusters, lower to 0.6 for looser.
CLUSTER_SIMILARITY_THRESHOLD=0.75
# -----------------------------------------------------------------------------
# GitHub Issues (optional; used by `founder-radar collect --source github`)
# -----------------------------------------------------------------------------
# Optional. Without it, the GitHub REST API allows 60 unauthenticated
# requests/hour per IP — enough for a small calibration scan. With a
# personal access token (or fine-grained token), the limit jumps to
# 5,000/hour, which makes multi-repo scans comfortable.
#
# To mint a token:
#   1. Visit https://github.com/settings/tokens (classic) OR
#      https://github.com/settings/personal-access-tokens (fine-grained)
#   2. For a classic token, no scopes are needed for public-issue reads.
#      For fine-grained tokens, enable "Public repositories" read access.
#   3. Paste the token below.
#
# Leave empty for unauthenticated use.
GITHUB_TOKEN=
# User-Agent sent on every GitHub API call. GitHub requires a unique UA.
GITHUB_USER_AGENT=founder-radar/0.1 (GitHub Issues collector; see project README)
# Base URL for the REST API. Override for GitHub Enterprise.
GITHUB_API_BASE=https://api.github.com
# Set to 'true' to keep issues authored by bot accounts (dependabot,
# renovate, github-actions). Default behavior filters them out at collection.
GITHUB_INCLUDE_BOTS=false
# Set to 'true' to keep template-only issues (empty body, generic title).
# Default behavior filters them out at collection.
GITHUB_INCLUDE_TEMPLATES=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO